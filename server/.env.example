# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# "sandbox" for testing, "development" for real banks (100 free connections), "production" for launch
PLAID_ENV=sandbox

# Server port
PORT=8080

# API key for authenticating app requests (generate a random string)
# Leave empty to disable auth (dev mode only)
API_KEY=

# Plaid webhook URL (your server's public URL + /api/plaid_webhook)
WEBHOOK_URL=

# Plaid webhook verification secret (from Plaid dashboard)
# Enables HMAC signature verification on incoming webhooks
PLAID_WEBHOOK_SECRET=

# CORS allowed origins (comma-separated). Leave empty for wildcard in dev.
# Example: http://localhost:3000,https://nodecompass.app
CORS_ORIGINS=
